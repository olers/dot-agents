{
  "name": "@linemagic/dot-agents",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "description": "把散落在 .claude/ .codex/ .cursor/ 等各个点目录里的 skills / commands / agents / hooks 收敛成唯一源 .agents/，其余目录只留软链",
  "keywords": ["agents", "skills", "claude-code", "symlink", "monorepo", "dotfiles"],
  "license": "MIT",
  "author": "LineMagic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olers/dot-agents.git"
  },
  "homepage": "https://github.com/olers/dot-agents#readme",
  "bugs": { "url": "https://github.com/olers/dot-agents/issues" },
  "type": "module",
  "bin": { "dot-agents": "./dist/cli/index.js" },
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "prepare": "npm run build",
    "test": "vitest run",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
